# Replicate API
# Get this from: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_your-replicate-api-token

# Site URL (used for sitemap and OG tags)
NEXT_PUBLIC_SITE_URL=https://goodbyewatermark.com

# Stripe
# Get keys from: https://dashboard.stripe.com/apikeys
# Use sk_test_... for development, sk_live_... for production
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# RapidAPI provider proxy secret
# The Rapid Runtime injects this value into the `X-RapidAPI-Proxy-Secret`
# header on every request it forwards to /api/v1/remove-watermark.
# Copy it from: Hub Listing > Gateway > Firewall Settings > Copy.
RAPIDAPI_PROXY_SECRET=your-rapidapi-proxy-secret